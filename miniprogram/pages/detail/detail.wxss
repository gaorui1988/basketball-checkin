.page { padding-bottom: 60rpx; }

.detail-header {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  padding: 40rpx 32rpx;
  color: #fff;
}
.status-badge.large {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-bottom: 16rpx;
}
.status-badge.large.open { background: rgba(46,204,113,0.3); color: #2ecc71; }
.status-badge.large.playing { background: rgba(52,152,219,0.3); color: #3498db; }
.status-badge.large.closed { background: rgba(149,165,166,0.3); color: #bdc3c7; }

.detail-title { font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }

.detail-meta { margin-bottom: 20rpx; }
.meta-item { font-size: 24rpx; margin-bottom: 12rpx; display: flex; align-items: center; }
.meta-icon { margin-right: 12rpx; }
.progress-bar.big { height: 12rpx; border-radius: 6rpx; background: rgba(255,255,255,0.2); }
.progress-bar.big .progress-fill { background: linear-gradient(90deg, #2ecc71, #27ae60); }

.action-bar { display: flex; gap: 16rpx; flex-wrap: wrap; padding: 24rpx; margin: 16rpx; }

.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }

.member-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin-right: 20rpx; }
.member-info { flex: 1; }
.member-name { font-size: 26rpx; font-weight: 500; display: block; }
.member-status { font-size: 22rpx; display: block; margin-top: 4rpx; }
.member-status.checked_in { color: #27ae60; }
.member-status.no_show { color: #e74c3c; }
.member-status.cancelled { color: #95a5a6; }
.member-status.signed { color: #3498db; }

.mark-btn {
  padding: 12rpx 20rpx;
  font-size: 22rpx;
  color: #e67e22;
  border: 2rpx solid #e67e22;
  border-radius: 8rpx;
}
.mark-btn:active { background: #e67e22; color: #fff; }

.badge-display {
  text-align: center;
  padding: 16rpx;
}
.badge-emoji { font-size: 36rpx; }

.footer-tip {
  margin: 32rpx 24rpx;
  padding: 20rpx;
  background: #fffdf0;
  border-radius: 12rpx;
  border: 2rpx solid #f0e6c0;
}
.tip-text { font-size: 24rpx; color: #8b7d3c; }
