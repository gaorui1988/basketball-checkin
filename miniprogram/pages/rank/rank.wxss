.page { padding-bottom: 60rpx; }

.rank-header {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  padding: 48rpx 32rpx;
  text-align: center;
  color: #fff;
}
.rank-title { font-size: 40rpx; font-weight: 700; display: block; }
.rank-sub { font-size: 24rpx; opacity: 0.7; margin-top: 8rpx; }

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  margin: 4rpx 0;
}
.rank-item.top { background: linear-gradient(135deg, #fffdf0, #fff8e1); }

.rank-medal { font-size: 36rpx; width: 60rpx; text-align: center; }
.rank-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin: 0 20rpx; }
.rank-info { flex: 1; }
.rank-name { font-size: 28rpx; font-weight: 500; display: block; }
.rank-grade { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

.rank-stats { text-align: right; }
.rank-score { font-size: 30rpx; font-weight: 700; display: block; }
.rank-detail { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
