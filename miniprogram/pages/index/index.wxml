<view class="page">
  <!-- 顶部Banner -->
  <view class="banner">
    <image class="banner-logo" src="/images/app-logo.png" mode="aspectFill"></image>
    <text class="banner-title">组一波</text>
    <text class="banner-sub">与球友一起，拒绝放鸽子</text>
  </view>

  <!-- 登录提示条 -->
  <view class="login-banner" wx:if="{{!isLoggedIn}}" bindtap="onShowLogin">
    <text class="login-banner-text">👤 设置昵称和头像，在排行榜露脸</text>
    <text class="login-banner-arrow">去设置 ›</text>
  </view>

  <!-- Tab切换 -->
  <view class="tab-bar">
    <view class="tab-item {{tabActive === 'open' ? 'active' : ''}}" 
          data-tab="open" bindtap="onSwitchTab">即将开始</view>
    <view class="tab-item {{tabActive === 'my' ? 'active' : ''}}" 
          data-tab="my" bindtap="onSwitchTab">我报名的</view>
    <view class="tab-item {{tabActive === 'past' ? 'active' : ''}}" 
          data-tab="past" bindtap="onSwitchTab">历史记录</view>
  </view>

  <!-- 活动列表 -->
  <block wx:if="{{!loading}}">
    <view class="activity-list">
      <activity-card 
        wx:for="{{activities}}" 
        wx:key="_id" 
        activity="{{item}}"
      />
      <view class="empty-state" wx:if="{{activities.length === 0}}">
        <text>暂无活动</text>
        <text class="empty-hint">点击下方按钮创建第一个活动吧</text>
      </view>
    </view>
  </block>

  <view class="loading-container" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 创建按钮 -->
  <view class="create-btn-wrap">
    <button class="btn-primary create-btn" bindtap="onCreate">＋ 组一波</button>
  </view>

  <!-- 授权弹窗 -->
  <view class="popup-mask" wx:if="{{showLoginPopup}}" bindtap="onClosePopup"></view>
  <view class="popup-card" wx:if="{{showLoginPopup}}">
    <text class="popup-title">设置资料</text>
    <text class="popup-desc">设置后在排行榜和活动中展示你的身份</text>
    
    <!-- 一键授权 -->
    <view class="onekey-section">
      <button class="onekey-btn" bindtap="onOneKeyAuth" loading="{{loginLoading}}">
        📱 一键授权微信信息
      </button>
      <text class="onekey-hint">直接使用微信昵称和头像</text>
    </view>

    <!-- 分隔线 -->
    <view class="divider"><text class="divider-text">或手动设置</text></view>

    <!-- 手动设置 -->
    <view class="manual-section">
      <view class="avatar-section">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{tempAvatarPath || '/images/default-avatar.png'}}"></image>
        </button>
        <text class="avatar-hint">点击换头像</text>
      </view>
      <input class="nickname-input" type="nickname" placeholder="输入昵称" 
             bindinput="onNicknameInput" />
    </view>

    <view class="popup-actions">
      <button class="popup-cancel" bindtap="onClosePopup">跳过</button>
      <button class="popup-confirm" bindtap="onSaveProfile" loading="{{loginLoading}}">保存</button>
    </view>
  </view>
</view>
