<view class="page">
  <!-- 顶部Banner -->
  <view class="banner">
    <image class="banner-logo" src="/images/app-logo.png" mode="aspectFill"></image>
    <text class="banner-title">组一波</text>
    <text class="banner-sub">与球友一起，拒绝放鸽子</text>
  </view>

  <!-- 登录提示条（点击直接授权） -->
  <button class="login-banner" wx:if="{{!isLoggedIn}}" bindtap="onOneKeyAuth">
    <text class="login-banner-text">👤 授权微信信息，在排行榜露脸</text>
    <text class="login-banner-arrow">立即授权 ›</text>
  </button>

  <!-- Tab切换 -->
  <view class="tab-bar">
    <view class="tab-item {{tabActive === 'open' ? 'active' : ''}}" 
          data-tab="open" bindtap="onSwitchTab">即将开始</view>
    <view class="tab-item {{tabActive === 'my' ? 'active' : ''}}" 
          data-tab="my" bindtap="onSwitchTab">我报名的</view>
    <view class="tab-item {{tabActive === 'past' ? 'active' : ''}}" 
          data-tab="past" bindtap="onSwitchTab">历史记录</view>
  </view>

  <!-- 活动列表 -->
  <block wx:if="{{!loading}}">
    <view class="activity-list">
      <activity-card 
        wx:for="{{activities}}" 
        wx:key="_id" 
        activity="{{item}}"
      />
      <view class="empty-state" wx:if="{{activities.length === 0}}">
        <text>暂无活动</text>
        <text class="empty-hint">点击下方按钮创建第一个活动吧</text>
      </view>
    </view>
  </block>

  <view class="loading-container" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 创建按钮 -->
  <view class="create-btn-wrap">
    <button class="btn-primary create-btn" bindtap="onCreate">＋ 组一波</button>
  </view>
</view>
