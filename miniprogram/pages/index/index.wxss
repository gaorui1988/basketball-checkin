.page { min-height: 100vh; padding-bottom: 140rpx; }

.banner {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 48rpx 32rpx;
  color: #fff;
}
.banner-title { font-size: 40rpx; font-weight: 700; display: block; }
.banner-sub { font-size: 24rpx; opacity: 0.7; margin-top: 8rpx; display: block; }

.login-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #e8f5e9;
  padding: 20rpx 24rpx;
  margin: 0 0 0 0;
}
.login-banner-text { font-size: 24rpx; color: #2e7d32; flex: 1; }
.login-banner-btn {
  display: inline-block;
  background: #2e7d32;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  line-height: 1;
  min-width: auto;
}
.login-banner-btn::after { border: none; }

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 26rpx;
  color: #999;
  position: relative;
}
.tab-item.active {
  color: #1a1a2e;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1a1a2e;
  border-radius: 2rpx;
}

.activity-list { padding: 16rpx 0; }

.empty-state {
  text-align: center;
  padding: 100rpx 48rpx;
}
.empty-hint { font-size: 24rpx; color: #ccc; display: block; margin-top: 16rpx; }

.create-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(transparent, #f5f5f5 30%);
}
.create-btn { width: 100%; }
