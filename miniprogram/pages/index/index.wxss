.page { min-height: 100vh; padding-bottom: 140rpx; }

.banner {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 48rpx 32rpx;
  color: #fff;
}
.banner-logo { width: 72rpx; height: 72rpx; border-radius: 16rpx; margin-bottom: 12rpx; }
.banner-title { font-size: 40rpx; font-weight: 700; display: block; }
.banner-sub { font-size: 24rpx; opacity: 0.7; margin-top: 8rpx; display: block; }

.login-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #e3f2fd;
  padding: 24rpx;
}
.login-banner-text { font-size: 24rpx; color: #1565c0; flex: 1; }
.login-banner-arrow { font-size: 24rpx; color: #1976d2; font-weight: 600; }

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 26rpx;
  color: #999;
  position: relative;
}
.tab-item.active {
  color: #1a1a2e;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1a1a2e;
  border-radius: 2rpx;
}

.activity-list { padding: 16rpx 0; }

.empty-state {
  text-align: center;
  padding: 100rpx 48rpx;
}
.empty-hint { font-size: 24rpx; color: #ccc; display: block; margin-top: 16rpx; }

.create-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(transparent, #f5f5f5 30%);
}
.create-btn { width: 100%; }

/* 授权弹窗 */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}
.popup-card {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 48rpx 40rpx 60rpx;
  z-index: 101;
}
.popup-title { font-size: 32rpx; font-weight: 700; display: block; text-align: center; }
.popup-desc { font-size: 24rpx; color: #999; display: block; text-align: center; margin-top: 12rpx; }

.avatar-section { text-align: center; margin: 32rpx 0; }
.avatar-btn {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 auto;
  background: #f0f0f0;
  border: 4rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.avatar-btn::after { border: none; }
.avatar-preview { width: 100%; height: 100%; border-radius: 50%; }
.avatar-hint { font-size: 22rpx; color: #999; display: block; margin-top: 12rpx; }

.nickname-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.popup-actions { display: flex; gap: 24rpx; }
.popup-cancel {
  flex: 1;
  background: #f0f0f0;
  color: #666;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  text-align: center;
}
.popup-cancel::after { border: none; }
.popup-confirm {
  flex: 1;
  background: #1a1a2e;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  text-align: center;
}
.popup-confirm::after { border: none; }

.onekey-section { text-align: center; margin: 32rpx 0; }
.onekey-btn { width: 100%; background: #07c160; color: #fff; border-radius: 12rpx; padding: 28rpx; font-size: 30rpx; }
.onekey-btn::after { border: none; }
.onekey-hint { font-size: 22rpx; color: #999; display: block; margin-top: 12rpx; }

.divider { display: flex; align-items: center; margin: 24rpx 0; }
.divider::before, .divider::after { content: ''; flex: 1; height: 2rpx; background: #eee; }
.divider-text { font-size: 22rpx; color: #ccc; padding: 0 24rpx; }
.manual-section { margin: 16rpx 0; }
