.form-page { padding: 32rpx; }
.form-group { margin-bottom: 40rpx; }
.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.form-input {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  border: 2rpx solid #eee;
}
.picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  border: 2rpx solid #eee;
  color: #333;
}
.form-actions {
  margin-top: 80rpx;
}
