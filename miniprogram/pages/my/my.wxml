<view class="page">
  <view class="loading-container" wx:if="{{loading}}"><text>加载中...</text></view>

  <block wx:if="{{!loading && stats}}">
    <!-- 用户卡片 -->
    <view class="user-card">
      <view class="user-card-head" bindtap="onShowLogin">
        <text class="user-icon">{{stats.avatarUrl ? '' : '🏀'}}</text>
        <image wx:if="{{stats.avatarUrl}}" class="user-avatar" src="{{stats.avatarUrl}}"></image>
        <text class="user-name">{{stats.nickName || '匿名球友'}}</text>
      </view>
      
      <!-- 未授权时显示登录按钮 -->
      <button wx:if="{{!isLoggedIn}}" class="login-btn" 
              bindtap="onShowLogin">
        点击设置昵称和头像
      </button>

      <view class="badge-row" wx:if="{{badge}}">
        <text class="user-badge">{{badge.label}}</text>
      </view>
      <view class="points-display">
        <text class="points-num">{{stats.points || 0}}</text>
        <text class="points-label">积分</text>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-row">
      <stat-card icon="📝" title="报名" value="{{stats.totalSignups || 0}}" color="#3498db"></stat-card>
      <stat-card icon="✅" title="到场" value="{{stats.totalCheckins || 0}}" color="#27ae60"></stat-card>
      <stat-card icon="🕊️" title="放鸽子" value="{{stats.totalNoShows || 0}}" color="#e74c3c"></stat-card>
      <stat-card icon="↩️" title="取消" value="{{stats.totalCancels || 0}}" color="#e67e22"></stat-card>
    </view>

    <!-- 积分规则 -->
    <view class="card rules-card">
      <text class="rules-title">📋 积分规则</text>
      <view class="rule-item"><text class="rule-icon">🟢</text> 报名+签到到场 → +10分</view>
      <view class="rule-item"><text class="rule-icon">🟡</text> 取消报名 → -5分</view>
      <view class="rule-item"><text class="rule-icon">🔴</text> 放鸽子(报名未到场) → -20分</view>
      <view class="rule-item"><text class="rule-icon">🏆</text> 连续5次到场 → 额外+15分</view>
    </view>

    <!-- 最近活动 -->
    <view class="card" wx:if="{{myActivities.length > 0}}">
      <view class="section-title"><text>📋 最近活动</text></view>
      <view class="activity-list">
        <view class="my-activity-item" wx:for="{{myActivities}}" wx:key="_id" 
              data-id="{{item.activityId}}" bindtap="onGoDetail">
          <text class="act-title">{{item.activityTitle}}</text>
          <text class="act-status {{item.status}}">{{item.displayStatus}}</text>
        </view>
      </view>
    </view>
  </block>
  
  <!-- 授权弹窗 -->
  <view class="popup-mask" wx:if="{{showLoginPopup}}" bindtap="onClosePopup"></view>
  <view class="popup-card" wx:if="{{showLoginPopup}}">
    <text class="popup-title">设置资料</text>
    <text class="popup-desc">设置后在排行榜和活动中展示你的身份</text>
    
    <view class="onekey-section">
      <button class="onekey-btn" bindtap="onOneKeyAuth" loading="{{profileLoading}}">
        📱 一键授权微信信息
      </button>
      <text class="onekey-hint">直接使用微信昵称和头像</text>
    </view>

    <view class="divider"><text class="divider-text">或手动设置</text></view>

    <view class="manual-section">
      <view class="avatar-section">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{tempAvatarPath || '/images/default-avatar.png'}}"></image>
        </button>
        <text class="avatar-hint">点击换头像</text>
      </view>
      <input class="nickname-input" type="nickname" placeholder="输入昵称" 
             bindinput="onNicknameInput" />
    </view>

    <view class="popup-actions">
      <button class="popup-cancel" bindtap="onClosePopup">跳过</button>
      <button class="popup-confirm" bindtap="onSaveProfile" loading="{{profileLoading}}">保存</button>
    </view>
  </view>
</view>
