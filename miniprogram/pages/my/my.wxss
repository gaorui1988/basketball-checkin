.page { padding-bottom: 60rpx; }

.user-card {
  text-align: center;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
}
.user-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.user-card-head { cursor: pointer; }
.user-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; margin-bottom: 16rpx; }
.user-name { font-size: 32rpx; font-weight: 600; display: block; }

.login-btn {
  margin-top: 20rpx;
  display: inline-block;
  background: rgba(255,255,255,0.15);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.3);
  border-radius: 12rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
}
.login-btn::after { border: none; }
.badge-row { margin-top: 12rpx; }
.user-badge {
  display: inline-block;
  padding: 4rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.15);
  font-size: 24rpx;
}
.points-display { margin-top: 24rpx; }
.points-num { font-size: 64rpx; font-weight: 700; display: block; }
.points-label { font-size: 24rpx; opacity: 0.7; }

.stats-row {
  display: flex;
  gap: 12rpx;
  padding: 24rpx;
}

.rules-card { margin-top: 0; }
.rules-title { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 16rpx; }
.rule-item { font-size: 24rpx; margin-bottom: 12rpx; }
.rule-icon { margin-right: 8rpx; }

.my-activity-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}
.my-activity-item:last-child { border-bottom: none; }
.act-title { font-size: 26rpx; color: #333; }
.act-status { font-size: 24rpx; }
.act-status.checked_in { color: #27ae60; }
.act-status.no_show { color: #e74c3c; }
.act-status.signed { color: #3498db; }
.act-status.cancelled { color: #95a5a6; }

/* 授权弹窗 - 复用首页样式 */
.popup-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.popup-card { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 48rpx 40rpx 60rpx; z-index: 101; }
.popup-title { font-size: 32rpx; font-weight: 700; display: block; text-align: center; }
.popup-desc { font-size: 24rpx; color: #999; display: block; text-align: center; margin-top: 12rpx; }
.avatar-section { text-align: center; margin: 32rpx 0; }
.avatar-btn { width: 128rpx; height: 128rpx; border-radius: 50%; padding: 0; margin: 0 auto; background: #f0f0f0; border: 4rpx solid #ddd; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.avatar-btn::after { border: none; }
.avatar-preview { width: 100%; height: 100%; border-radius: 50%; }
.avatar-hint { font-size: 22rpx; color: #999; display: block; margin-top: 12rpx; }
.nickname-input { background: #f5f5f5; border-radius: 12rpx; padding: 24rpx 28rpx; font-size: 28rpx; text-align: center; margin-bottom: 40rpx; }
.popup-actions { display: flex; gap: 24rpx; }
.popup-cancel { flex: 1; background: #f0f0f0; color: #666; border-radius: 12rpx; padding: 24rpx; font-size: 28rpx; text-align: center; }
.popup-cancel::after { border: none; }
.popup-confirm { flex: 1; background: #1a1a2e; color: #fff; border-radius: 12rpx; padding: 24rpx; font-size: 28rpx; text-align: center; }
.popup-confirm::after { border: none; }

.onekey-section { text-align: center; margin: 32rpx 0; }
.onekey-btn { width: 100%; background: #07c160; color: #fff; border-radius: 12rpx; padding: 28rpx; font-size: 30rpx; }
.onekey-btn::after { border: none; }
.onekey-hint { font-size: 22rpx; color: #999; display: block; margin-top: 12rpx; }

.divider { display: flex; align-items: center; margin: 24rpx 0; }
.divider::before, .divider::after { content: ''; flex: 1; height: 2rpx; background: #eee; }
.divider-text { font-size: 22rpx; color: #ccc; padding: 0 24rpx; }
.manual-section { margin: 16rpx 0; }
