/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
  transition: opacity 0.2s;
}
.btn-primary:active { opacity: 0.8; }

.btn-danger {
  background: #e74c3c;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}
.btn-danger:active { opacity: 0.8; }

.btn-success {
  background: #27ae60;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}
.btn-success:active { opacity: 0.8; }

.btn-small {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 加载 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
  color: #999;
  font-size: 28rpx;
}
.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}
